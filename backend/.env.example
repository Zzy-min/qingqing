# MiniMax Photo Agent 配置
# 复制此文件为 .env 并填入你的 API Key。
# 注意：这里只能放占位符，不要提交真实密钥到仓库、截图或日志。

# MiniMax API 密钥 (必须)
MINIMAX_API_KEY=your_api_key_here

# MiniMax Group ID (可选，默认 1425)
MINIMAX_GROUP_ID=1425

# 最短启动说明：
# 后端：cd backend && python -m pip install -r requirements.txt && uvicorn main:app --host 0.0.0.0 --port 8001 --reload
# 前端：cd frontend && npm install && npm run dev
